# Jarvis Telegram Bot — Environment Variables
# Copy to .env and fill in values

# Required
TELEGRAM_BOT_TOKEN=           # From @BotFather
TELEGRAM_ALLOWED_USERS=8445149012  # Comma-separated Telegram user IDs

# Photo/Voice/Text Analysis (optional but recommended)
GROQ_API_KEY=                 # Groq API key (groq.com)

# Atlas CMMS Integration (optional)
CMMS_URL=                     # e.g. http://72.60.175.144:8080
CMMS_EMAIL=                   # CMMS login email
CMMS_PASSWORD=                # CMMS login password

# Claude CLI Bridge (optional)
CLAUDE_WORKSPACE=             # Path to workspace for Claude CLI

# Bot Identity
MACHINE_NAME=jarvis           # Device identifier

# Tuning (optional)
TELEGRAM_RATE_LIMIT=10        # Max messages per minute per user
TELEGRAM_LOG_CONVERSATIONS=false  # GDPR: keep false in production
